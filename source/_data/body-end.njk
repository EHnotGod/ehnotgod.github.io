<script>
// KaTeX client-side rendering
// hexo-renderer-kramed: $$...$$ -> <script type="math/tex">，$...$ -> 原样保留
(function() {
  function renderMath() {
    if (typeof katex === 'undefined') return;

    // 1. 处理 $$...$$ 生成的 <script type="math/tex"> 标签
    document.querySelectorAll('script[type="math/tex"]').forEach(function(el) {
      var tex = el.textContent;
      var span = document.createElement('span');
      try { katex.render(tex, span, { throwOnError: false, displayMode: false }); }
      catch(e) { span.textContent = tex; }
      el.parentNode.replaceChild(span, el);
    });
    document.querySelectorAll('script[type="math/tex; mode=display"]').forEach(function(el) {
      var tex = el.textContent;
      var div = document.createElement('div');
      div.className = 'katex-display';
      try { katex.render(tex, div, { throwOnError: false, displayMode: true }); }
      catch(e) { div.textContent = tex; }
      el.parentNode.replaceChild(div, el);
    });

    // 2. 处理 $...$ 原样保留在文本里的公式（用 auto-render）
    if (typeof renderMathInElement === 'function') {
      renderMathInElement(document.body, {
        delimiters: [
          { left: '$$', right: '$$', display: true },
          { left: '$',  right: '$',  display: false }
        ],
        throwOnError: false
      });
    }
  }

  function loadScript(src, onload) {
    if (document.querySelector('script[src="' + src + '"]')) { onload && onload(); return; }
    var s = document.createElement('script');
    s.src = src; s.crossOrigin = 'anonymous'; s.onload = onload;
    document.head.appendChild(s);
  }

  function init() {
    if (typeof katex !== 'undefined') {
      if (typeof renderMathInElement !== 'undefined') {
        renderMath();
      } else {
        loadScript('https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/contrib/auto-render.min.js', renderMath);
      }
    } else {
      loadScript('https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/katex.min.js', function() {
        loadScript('https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/contrib/auto-render.min.js', renderMath);
      });
    }
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('page:loaded', init);
})();
</script>
<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var categoryList = document.querySelector('.category-all .category-list');
    if (!categoryList) return;

    var leafItems = [];

    categoryList.querySelectorAll('li.category-list-item').forEach(function(item) {
      var child = item.querySelector(':scope > ul.category-list-child');
      var link = item.querySelector(':scope > a.category-list-link');

      var toggle = document.createElement('span');
      toggle.className = 'category-toggle';
      toggle.setAttribute('aria-hidden', 'true');
      toggle.textContent = '▸';
      toggle.addEventListener('click', function(event) {
        event.preventDefault();
        event.stopPropagation();
        item.classList.toggle('collapsed');
        item.classList.toggle('expanded');
      });

      if (child) {
        // 有子分类：添加折叠按钮
        item.classList.add('has-child', 'collapsed');
        if (link) item.insertBefore(toggle, link);
      } else {
        // 叶子分类：先记录，等 search.json 加载后填充文章
        item.dataset.leafPending = '1';
        leafItems.push({ item: item, link: link, toggle: toggle });
      }
    });

    if (!leafItems.length) return;

    fetch('/search.json')
      .then(function(res) { return res.json(); })
      .then(function(posts) {
        // 用解码后的路径作为 key，避免编码差异
        var catMap = {};
        posts.forEach(function(post) {
          if (!post.categories || !post.categories.length) return;
          // Hexo 将分类名中的空格转为连字符
          var key = '/categories/' + post.categories.map(function(c) {
            return c.replace(/ /g, '-');
          }).join('/') + '/';
          if (!catMap[key]) catMap[key] = [];
          catMap[key].push(post);
        });

        leafItems.forEach(function(entry) {
          var item = entry.item;
          var link = entry.link;
          var toggle = entry.toggle;
          if (!link) return;

          var decodedHref = decodeURIComponent(link.getAttribute('href'));
          var matchedPosts = catMap[decodedHref] || [];
          if (!matchedPosts.length) return;

          // 按标题中的字母+数字部分排序，如 A1 < A2 < A10
          matchedPosts.sort(function(a, b) {
            var re = /^([A-Za-z]+)(\d+(?:\.\d+)*)/;
            var ma = re.exec(a.title), mb = re.exec(b.title);
            if (!ma || !mb) return a.title.localeCompare(b.title);
            if (ma[1] !== mb[1]) return ma[1].localeCompare(mb[1]);
            var na = ma[2].split('.').map(Number), nb = mb[2].split('.').map(Number);
            for (var i = 0; i < Math.max(na.length, nb.length); i++) {
              var diff = (na[i] || 0) - (nb[i] || 0);
              if (diff !== 0) return diff;
            }
            return 0;
          });

          // 构建文章列表（复用已有样式类）
          var postList = document.createElement('ul');
          postList.className = 'category-list-child';
          matchedPosts.forEach(function(post) {
            var li = document.createElement('li');
            li.className = 'category-list-item';
            var a = document.createElement('a');
            a.href = post.url;
            a.className = 'category-list-link category-post-link';
            a.textContent = post.title;
            li.appendChild(a);
            postList.appendChild(li);
          });

          item.classList.add('has-child', 'collapsed');
          item.insertBefore(toggle, link);
          item.appendChild(postList);
        });
      })
      .catch(function() {});
  });
})();
</script>
